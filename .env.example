BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 请复制本文件为 .env，并把下面的示例值改成你自己的数据库连接信息。
#
# 如果 PostgreSQL 安装在 Windows，而 FastAPI 后端运行在 WSL Ubuntu 中，
# your_host_ip 可能不是 127.0.0.1。可以在 WSL 中执行：
#
# cat /etc/resolv.conf
#
# 找到 nameserver 后面的 IP，并将其填入 DATABASE_URL。
DATABASE_URL=postgresql+psycopg2://postgres:your_password@your_host_ip:5432/soft_soil_db

MODEL_DIR=src/ml/saved_models
RISK_MODEL_PATH=src/ml/saved_models/risk_model.pkl
MODEL_METADATA_PATH=src/ml/saved_models/model_metadata.json
